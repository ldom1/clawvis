# reverse-prompt Skill Configuration

# Required: Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Fallback LLM (for cost optimization)
MAMMOUTH_API_KEY=...

# Optional: Model selection
# Options: claude-haiku (default), claude-opus, claude-sonnet
REVERSE_PROMPT_MODEL=claude-haiku

# Optional: Iterations for RPEGA algorithm
# Range: 1-10 (default: 3)
# Higher = more accurate but slower
REVERSE_PROMPT_ITERATIONS=3

# Optional: Confidence threshold
# Range: 0.0-1.0 (default: 0.85)
# Output rejected if confidence < threshold
REVERSE_PROMPT_CONFIDENCE_THRESHOLD=0.85

# Optional: Logging level
# Options: DEBUG, INFO, WARNING, ERROR
REVERSE_PROMPT_LOG_LEVEL=INFO

# Optional: Cache results
# When enabled, same inputs return cached prompts
REVERSE_PROMPT_CACHE_ENABLED=true
REVERSE_PROMPT_CACHE_DIR=~/.openclaw/cache/reverse-prompt

# Optional: Integration with LabOS
# Path to style guide example
LABOS_STYLE_GUIDE=/home/lgiron/Lab/dombot-labos/standards/report-style.txt
