{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "async": false
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(docker*)",
      "Bash(docker compose*)",
      "Bash(yarn --cwd hub*)",
      "Bash(npm*)",
      "Bash(uv*)",
      "Bash(bash tests/*)",
      "Bash(bash scripts/*)",
      "Bash(./clawvis*)",
      "Bash(clawvis*)",
      "Bash(rtk*)",
      "Bash(git*)"
    ]
  }
}
