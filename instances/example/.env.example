# .env.example — Instance environment variables
# Copy to .env.local and fill in your values (never commit .env.local)

# LLM Providers
MAMMOUTH_API_KEY=your_mammouth_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Agent identity
AGENT_ID=your-agent-name
AGENT_ROLE=ORCHESTRATOR

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token_here

# Discord notifications (optional)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID_OPS=
DISCORD_CHANNEL_ID_LOGS=
DISCORD_CHANNEL_ID_ALERTS=
