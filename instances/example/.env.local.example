# .env.local.example — instance-specific environment variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local (it is gitignored).
#
# Values here override the root .env for this instance.

# AI provider keys (set whichever you use)
CLAUDE_API_KEY=sk-ant-...
MISTRAL_API_KEY=
OPENCLAW_BASE_URL=http://localhost:3333
OPENCLAW_API_KEY=

# Instance identity (set by installer — change only if you rename the instance)
# INSTANCE_NAME=example

# Optional: override ports for this instance
# HUB_PORT=8088
# MEMORY_PORT=3099
# KANBAN_API_PORT=8090
# HUB_MEMORY_API_PORT=8091
