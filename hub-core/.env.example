# MammouthAI — unified gateway (Claude, Gemini, Mistral, GPT via single endpoint)
# Get your key at https://mammouth.ai → Settings → API Keys
MAMMOUTH_API_KEY=your_mammouth_api_key_here

# Direct provider keys (optional — only needed if not using MammouthAI gateway)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Agent identity (used by hub_core.security + logged to ~/.openclaw/logs/)
AGENT_ID=hub-core
AGENT_ROLE=AGENT
# AGENT_IDENTITY=hub-core@labos.local   # derived from AGENT_ID if unset
AGENT_MODEL=claude-haiku-4-5

# Network policy: unrestricted | restricted | allowlist
NETWORK_MODE=restricted
# NETWORK_ALLOWLIST=api.anthropic.com,api.mammouth.ai

# Optional: override Lab root if different
# LAB_DIR=/home/youruser/Lab

