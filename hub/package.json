{
  "name": "clawvis-hub",
  "private": true,
  "version": "0.1.0",
  "packageManager": "yarn@4.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"vite.config.js\" \"index.html\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\" \"vite.config.js\" \"index.html\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "vite": "^7.1.5"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "marked": "^15.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
