# ==========================================
# Clawvis - Environment Variables Example
# Copy this file to .env and fill values.
# ==========================================

# ------------------------------------------
# 1) LLM Providers
# ------------------------------------------
# Required for Claude-based flows
CLAUDE_API_KEY=sk-ant-...

# Optional providers (multi-agent routing)
MISTRAL_API_KEY=
GEMINI_API_KEY=
OPENCLAW_BASE_URL=http://localhost:3333
OPENCLAW_API_KEY=

# ------------------------------------------
# 2) Local Hub / Dev Runtime
# ------------------------------------------
# Port for hub (docker + ./start.sh default)
HUB_PORT=8088
# Kanban API local port used by ./start.sh
KANBAN_API_PORT=8090
# Optional Vite container port for `docker compose --profile dev up hub-vite`
HUB_VITE_PORT=5173
# Brain runtime (Obsidian-like docker)
MEMORY_PORT=3099
# Run memory container as host user (avoids root/nobody-owned files on bind mount)
HOST_UID=1000
HOST_GID=1000

# Optional legacy HUB_ROOT (used by some auxiliary skills/scripts).
# Uncomment/edit if you rely on those scripts.
# HUB_ROOT=/home/user/Lab/hub

# ------------------------------------------
# 3) Project Hub Defaults
# ------------------------------------------
# Instance scope used for runtime data
INSTANCE_NAME=example
# Memory root for Brain runtime (instance-scoped)
MEMORY_ROOT=instances/example/memory
# Used by settings page as initial target path
PROJECTS_ROOT=/home/user/lab_perso/projects

# ------------------------------------------
# 4) Deploy Script (deploy.sh)
# ------------------------------------------
# Target SSH host (IP or DNS)
DEPLOY_HOST=
# SSH user
DEPLOY_USER=
# Remote path where project is synced
DEPLOY_PATH=/opt/clawvis
# SSH port
DEPLOY_SSH_PORT=22
