# ==========================================
# Clawvis - Environment Variables Example
# Copy this file to .env and fill values.
# ==========================================

# ------------------------------------------
# 1) LLM Providers
# ------------------------------------------
# Required for Claude-based flows
CLAUDE_API_KEY=sk-ant-...

# Optional providers (multi-agent routing)
MISTRAL_API_KEY=
GEMINI_API_KEY=
OPENCLAW_BASE_URL=http://localhost:3333
OPENCLAW_API_KEY=

# ------------------------------------------
# 2) Local Hub / Dev Runtime
# ------------------------------------------
# Port for hub (docker + ./start.sh default)
HUB_PORT=8088
# Kanban API local port used by ./start.sh
KANBAN_API_PORT=8090
# Hub Memory API (Brain / Quartz / hub settings) — ./start.sh + docker hub-memory-api
HUB_MEMORY_API_PORT=8091
# Optional Vite container port for `docker compose --profile dev up hub-vite`
HUB_VITE_PORT=5173
# Brain runtime (Logseq web app)
MEMORY_PORT=3099
# Run memory container as host user (avoids root/nobody-owned files on bind mount)
HOST_UID=1000
HOST_GID=1000

# Optional legacy HUB_ROOT (used by some auxiliary skills/scripts).
# Uncomment/edit if you rely on those scripts.
# HUB_ROOT=/home/user/Lab/hub

# ------------------------------------------
# 3) Project Hub Defaults
# ------------------------------------------
# Instance scope used for runtime data
INSTANCE_NAME=example
# Memory root for Brain runtime (instance-scoped)
MEMORY_ROOT=instances/example/memory
# Used by settings page as initial target path
PROJECTS_ROOT=/home/user/lab_perso/projects

# ------------------------------------------
# 4) Deploy Script (deploy.sh / clawvis deploy)
# ------------------------------------------
# Target SSH host (IP or DNS) — e.g. your Hostinger VPS IP
DEPLOY_HOST=
# SSH user (e.g. ubuntu, root)
DEPLOY_USER=
# Remote path where project is synced
DEPLOY_PATH=/opt/clawvis
# SSH port (default 22)
DEPLOY_SSH_PORT=22

# ------------------------------------------
# 5) OpenClaw (self-hosted, optional)
# ------------------------------------------
# If you have an OpenClaw instance running (e.g. on Hostinger):
# OPENCLAW_BASE_URL=https://openclaw.yourdomain.com
# OPENCLAW_API_KEY=your-secret-key

# ------------------------------------------
# Hostinger VPS quick-start:
# 1. Set DEPLOY_HOST / DEPLOY_USER / DEPLOY_PATH above
# 2. Run: clawvis deploy   (or: bash scripts/deploy.sh)
# 3. On the VPS, set up nginx as a reverse proxy to port HUB_PORT
# 4. Optional: set OPENCLAW_BASE_URL to your OpenClaw instance URL
# ------------------------------------------
